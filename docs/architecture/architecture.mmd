subgraph SRC["1 · Ingestion"]
  direction TB
  Crawler["Scrapy Crawler\ntiki_crawl.py"]
  Bronze[("MinIO / S3\nbronze")]
  Crawler --> Bronze
end

subgraph CICD["CI/CD"]
  direction TB
  GH["GitHub"] --> GA["Actions"] --> ECR[("ECR")] --> EC2["EC2 host"]
  TF["Terraform"] -.provisions.-> EC2
end

subgraph BATCH["2 · Batch ETL — Airflow"]
  direction TB
  Spark["Spark\nbronze_to_silver.py"]
  DBT["dbt\nstg_products / stg_comments"]
  Silver[("Iceberg silver")]
  PhoBatch["PhoBERT batch\ninference_job.py"]
  Gold[("Iceberg gold\nsentiment scored")]
  Spark --> Silver --> DBT
  Silver --> PhoBatch --> Gold
end

subgraph STREAM["3 · Streaming"]
  direction TB
  Producer["recsys-producer"]
  Broker{{"Kafka"}}
  Consumer["stream.py\nconsumer"]
  DLQ[("new_reviews_dlq")]
  Producer --> Broker --> Consumer --> DLQ
end

subgraph TRAIN["4 · Offline Training — local CPU + Kaggle GPU"]
  direction TB
  NegSample["Negative Sampling\n(local, CPU)"]
  TwoTower["Two-Tower\nInfoNCE"]
  SASRec["SASRec\nsequential"]
  LTR["LTR Reranker\nXGBoost LambdaMART"]
  MLflowReg[("MLflow\nRegistry")]
  NegSample --> TwoTower --> LTR
  NegSample --> SASRec
  TwoTower & SASRec & LTR --> MLflowReg
end

subgraph STORE["5 · Feature, Vector & Cache Store"]
  direction TB
  FeastOff[("Feast Offline\nParquet")]
  FeastOn[("Feast Online\nRedis db1")]
  Qdrant[("Qdrant\nvectors")]
  RedisCache[("Redis\ncache/memory/rate-limit")]
  FeastOff --> FeastOn
end

subgraph SERVE["6 · Serving APIs"]
  direction TB
  RecsysAPI["recsys-api  :8001\nTwo-Tower + reranker + A/B"]
  AgentAPI["agent-api  :8003\nLangGraph ReAct + RAG + guardrails"]
  NlpAPI["sentiment-api  :8000\nPhoBERT ONNX"]
end

subgraph LLM["7 · LLM Backend"]
  direction TB
  Ollama["Ollama\nQwen2.5-3B (CPU)"]
  VLLM["vLLM · GPU Spot\nQwen2.5-7B-AWQ"]
  Claude["Claude API"]
end

subgraph OBS["8 · Observability"]
  direction TB
  Prom["Prometheus"] --> Graf["Grafana"]
  Prom --> Alert["Alertmanager"]
  Jaeger["Jaeger\nOTel traces"]
end

Customer(["Customer"])
MLE(["ML / AI Engineer"])

%% ── core pipeline (kept at node-level: this is the interesting flow) ──
Bronze --> Spark
Gold --> NegSample
Consumer -->|"real-time score"| NlpAPI --> FeastOn
MLflowReg -->|"load weights"| RecsysAPI

%% ── state layer → serving (collapsed to 2 edges, not 6) ──
STORE ==>|"features + vectors + cache"| RecsysAPI
STORE ==>|"vectors + memory + cache"| AgentAPI

AgentAPI --> Ollama
AgentAPI --> VLLM
AgentAPI --> Claude

Customer -->|"chat"| AgentAPI
Customer -->|"browse / recommend"| RecsysAPI

%% ── cross-cutting concerns: one edge per concern, not one per node ──
SERVE -.->|"metrics + traces"| OBS
CICD -.->|"builds & deploys"| SERVE
MLE -->|"trains"| TRAIN
MLE -->|"commits"| CICD

class Crawler,Bronze ingest
class Spark,DBT,Silver,PhoBatch,Gold ingest
class Producer,Broker,Consumer,DLQ ingest
class NegSample,TwoTower,SASRec,LTR,MLflowReg train
