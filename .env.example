# ----------------------------
# POSTGRES
# ----------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=iceberg_metadata

# Iceberg catalog (JDBC) — docker-compose.infra.yml dùng ${VAR} KHÔNG có default,
# thiếu là compose truyền chuỗi rỗng và Spark không kết nối được catalog.
# Trên AWS các biến này đến từ Secrets Manager (terraform/phase1/secrets.tf).
POSTGRES_ICEBERG_USER=admin
POSTGRES_ICEBERG_PASSWORD=password
POSTGRES_ICEBERG_DB=iceberg_metadata

# pgAdmin — chỉ là công cụ dev, nằm sau profile "dev" (không chạy trên EC2).
# Bật khi cần: docker compose --profile dev up -d pgadmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# ----------------------------
# MINIO
# ----------------------------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password

# ----------------------------
# KAFKA / CONNECT (nếu cần dùng sau)
# ----------------------------

# ----------------------------
# REDIS
# ----------------------------
REDIS_PASSWORD=123
REDIS_HOST=redis
REDIS_PORT=6379

# ----------------------------
# AGENT API SECURITY
# ----------------------------
ADMIN_API_KEY=doi-key-nay-truoc-khi-deploy
# Rate limit theo IP cho /chat/stream (mỗi request tốn token LLM = tốn tiền).
IP_RATE_LIMIT_PER_MIN=60

# Trần chi phí LLM mỗi ngày (USD). Rate limit chặn SỐ REQUEST; cái này chặn TIỀN
# — 1 request context dài + nhiều vòng tool-call tốn gấp hàng chục lần request
# thường, nên rate limit thôi là chưa đủ.
#   USER_*   : 1 user lạm dụng thì chỉ user đó bị chặn.
#   GLOBAL_* : circuit breaker cho cả hệ thống (bug retry loop, bị scrape...).
USER_DAILY_BUDGET_USD=0.50
GLOBAL_DAILY_BUDGET_USD=5.00

# ----------------------------
# METABASE DB (dùng chung Postgres)
# ----------------------------
MB_DB_USER=admin
MB_DB_PASS=password
MB_DB_NAME=iceberg_metadata
MB_DB_HOST=postgres-catalog
MB_DB_PORT=5432

# ----------------------------
# AWS (MinIO S3 compatible)
# ----------------------------
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
AWS_REGION=us-east-1

# ----------------------------
# AGENT API — LLM + Embedding
# ----------------------------
# LLM backend: "ollama" (local) hoặc "claude" (API)
AGENT_LLM_BACKEND=ollama

# Ollama: model name (chỉ dùng khi AGENT_LLM_BACKEND=ollama)
# Options: qwen2.5:7b (mặc định, tốt nhất), qwen2.5:3b (nhẹ hơn), qwen2.5:1.5b (không khuyến nghị cho agent)
OLLAMA_MODEL=qwen2.5:7b

LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
AGENT_SUMMARIZE_AFTER=12
AGENT_KEEP_RECENT=6

# Claude API key (chỉ dùng khi AGENT_LLM_BACKEND=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Embedding model cho semantic search + KB indexer
# Benchmark tiếng Việt: dangvantuan (88.3) > bkai (78.0)
EMBEDDING_MODEL=dangvantuan/vietnamese-embedding


GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ----------------------------
# AIRFLOW
# ----------------------------
AIRFLOW_UID=50000

# ----------------------------
# AIRFLOW VARIABLES (set qua UI hoặc CLI)
# Sau khi Airflow up, chạy:
#   airflow variables set AWS_ACCESS_KEY_ID admin
#   airflow variables set AWS_SECRET_ACCESS_KEY password
#   airflow variables set AWS_REGION us-east-1
#   airflow variables set CATALOG_WAREHOUSE s3a://warehouse/
#   airflow variables set CATALOG_S3_ENDPOINT http://minio:9000
#
# Hoặc import 1 lần qua JSON:
#   airflow variables import airflow/config/variables.json
# ----------------------------
