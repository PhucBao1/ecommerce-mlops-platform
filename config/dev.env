# ─── Development environment ───────────────────────────────────────────────────
# Services run locally (not inside Docker), so use localhost instead of service names.
# LOG_LEVEL=DEBUG for verbose output during development.

LOG_LEVEL=DEBUG
ENV=dev

# ─── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# ─── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_ICEBERG_USER=admin
POSTGRES_ICEBERG_PASSWORD=password
POSTGRES_ICEBERG_DB=iceberg_metadata

POSTGRES_MLFLOW_USER=mlflow
POSTGRES_MLFLOW_PASSWORD=mlflow
POSTGRES_MLFLOW_DB=mlflow

POSTGRES_AIRFLOW_USER=airflow
POSTGRES_AIRFLOW_PASSWORD=airflow
POSTGRES_AIRFLOW_DB=airflow

# ─── MinIO (S3-compatible) ──────────────────────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
AWS_REGION=us-east-1
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
CATALOG_WAREHOUSE=s3a://warehouse/
CATALOG_S3_ENDPOINT=http://localhost:9000

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=123
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://:123@localhost:6379

# ─── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ─── OpenTelemetry / Jaeger ────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ─── Metabase ──────────────────────────────────────────────────────────────────
MB_DB_USER=admin
MB_DB_PASS=password
MB_DB_NAME=iceberg_metadata
MB_DB_HOST=localhost
MB_DB_PORT=5432

# ─── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
