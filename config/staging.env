# ─── Staging environment ────────────────────────────────────────────────────────
# Services run inside Docker Compose network — use service names as hostnames.
# Used in CI/CD pipelines and pre-production testing.
# Sensitive values (passwords, API keys) must be injected via CI/CD secrets —
# DO NOT hardcode real credentials here. Placeholders use ${VAR_NAME} syntax,
# same convention as prod.env (dev.env keeps literal dev-only defaults since
# those containers are local-only and not reachable from outside).

LOG_LEVEL=INFO
ENV=staging

# ─── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=${STAGING_PGADMIN_EMAIL}
PGADMIN_DEFAULT_PASSWORD=${STAGING_PGADMIN_PASSWORD}

# ─── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_ICEBERG_USER=${STAGING_POSTGRES_ICEBERG_USER}
POSTGRES_ICEBERG_PASSWORD=${STAGING_POSTGRES_ICEBERG_PASSWORD}
POSTGRES_ICEBERG_DB=iceberg_metadata

POSTGRES_MLFLOW_USER=${STAGING_POSTGRES_MLFLOW_USER}
POSTGRES_MLFLOW_PASSWORD=${STAGING_POSTGRES_MLFLOW_PASSWORD}
POSTGRES_MLFLOW_DB=mlflow

POSTGRES_AIRFLOW_USER=${STAGING_POSTGRES_AIRFLOW_USER}
POSTGRES_AIRFLOW_PASSWORD=${STAGING_POSTGRES_AIRFLOW_PASSWORD}
POSTGRES_AIRFLOW_DB=airflow

# ─── MinIO (S3-compatible) ──────────────────────────────────────────────────────
MINIO_ROOT_USER=${STAGING_MINIO_ROOT_USER}
MINIO_ROOT_PASSWORD=${STAGING_MINIO_ROOT_PASSWORD}
AWS_ACCESS_KEY_ID=${STAGING_AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${STAGING_AWS_SECRET_ACCESS_KEY}
AWS_REGION=us-east-1
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
CATALOG_WAREHOUSE=s3a://warehouse/
CATALOG_S3_ENDPOINT=http://minio:9000

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=${STAGING_REDIS_PASSWORD}
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:${STAGING_REDIS_PASSWORD}@redis:6379

# ─── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ─── OpenTelemetry / Jaeger ────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# ─── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=${STAGING_GRAFANA_USER}
GF_SECURITY_ADMIN_PASSWORD=${STAGING_GRAFANA_PASSWORD}

# ─── Metabase ──────────────────────────────────────────────────────────────────
MB_DB_USER=${STAGING_POSTGRES_ICEBERG_USER}
MB_DB_PASS=${STAGING_POSTGRES_ICEBERG_PASSWORD}
MB_DB_NAME=iceberg_metadata
MB_DB_HOST=postgres-catalog
MB_DB_PORT=5432

# ─── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000

# ─── Slack alerts (Alertmanager) ────────────────────────────────────────────────
SLACK_WEBHOOK_URL=${STAGING_SLACK_WEBHOOK_URL}
