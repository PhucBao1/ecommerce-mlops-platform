# dbt runtime data — generated, and local connection profile
dbt_project/target/
dbt_project/logs/
dbt_project/dbt_packages/
# Ignore NỘI DUNG của .dbt/, không phải bản thân thư mục: git không đi vào thư mục
# đã bị exclude, nên "dbt_project/.dbt/" + "!.../profiles.yml" sẽ KHÔNG hoạt động
# (không re-include được file nằm trong thư mục cha đã bị loại).
dbt_project/.dbt/*
# profiles.yml KHÔNG chứa secret (auth: NONE, chỉ hostname nội bộ Docker) nhưng
# docker/Dockerfile.dbt lại COPY nó => clone repo trên EC2 mà thiếu file này là
# build dbt image chết.
!dbt_project/.dbt/profiles.yml

