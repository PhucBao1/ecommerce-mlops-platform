{
  "title": "RecSys — All-in-One",
  "uid": "recsys-all-in-one",
  "tags": [
    "recsys"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "SLO / Overview",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate (RPS)",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_requests_total{job=\"fastapi-recsys\"}[1m]))",
          "legendFormat": "RPS"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P95 Latency",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 200
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(recommendation_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cold Start Rate",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.3
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(cold_start_total[5m]) / rate(http_requests_total{job=\"fastapi-recsys\"}[5m])",
          "legendFormat": "Cold Start %"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Error Rate (4xx+5xx %)",
      "description": "1 trong 4 Golden Signals (Rate/Errors/Duration/Saturation) — trước đây thiếu hẳn panel Errors.",
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_requests_total{status_code=~\"4..|5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
          "legendFormat": "error_rate_pct"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Cold Start Count",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(cold_start_total[5m])",
          "legendFormat": "Cold Starts/s"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Rate-Limit Rejections (429/s)",
      "description": "Theo dõi tần suất client bị chặn bởi rate-limit (60/phút/client) — phát hiện abuse hoặc giới hạn quá chặt với user thật.",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_requests_total{status_code=\"429\"}[5m]))",
          "legendFormat": "429/s"
        }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "Latency Deep-Dive",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Latency Percentiles",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum(rate(recommendation_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P50"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(recommendation_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P95"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum(rate(recommendation_latency_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Request Rate by Source",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(recommendation_latency_seconds_count[1m])) by (source)",
          "legendFormat": "{{source}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Recommend Stage Breakdown (feature_prep vs model vs faiss vs rerank)",
      "description": "Thêm sau khi đo thấy feature_prep (pandas overhead) chiếm 78% latency, model inference chỉ ~4% — cơ sở quyết định không đáng làm ONNX cho user_tower.",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(recommend_feature_prep_latency_seconds_sum[5m]) / rate(recommend_feature_prep_latency_seconds_count[5m]) * 1000",
          "legendFormat": "feature_prep (pandas)"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(recommend_model_inference_latency_seconds_sum[5m]) / rate(recommend_model_inference_latency_seconds_count[5m]) * 1000",
          "legendFormat": "model_inference (PyTorch)"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(recommend_faiss_retrieval_latency_seconds_sum[5m]) / rate(recommend_faiss_retrieval_latency_seconds_count[5m]) * 1000",
          "legendFormat": "faiss_retrieval"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(recommend_rerank_latency_seconds_sum[5m]) / rate(recommend_rerank_latency_seconds_count[5m]) * 1000",
          "legendFormat": "rerank"
        }
      ]
    },
    {
      "id": 12,
      "type": "row",
      "title": "Model Metrics",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 13,
      "type": "stat",
      "title": "NDCG@10 (Latest Run)",
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "green",
                "value": 0.1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "mlflow_metric{name=\"ndcg_at_10\"}",
          "legendFormat": "NDCG@10"
        }
      ]
    },
    {
      "id": 14,
      "type": "stat",
      "title": "AUC (Latest Run)",
      "gridPos": {
        "x": 6,
        "y": 31,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.6
              },
              {
                "color": "green",
                "value": 0.75
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "mlflow_metric{name=\"auc\"}",
          "legendFormat": "AUC"
        }
      ]
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Model Source Split (Model %)",
      "description": "% requests served by Two-Tower model (vs cold start trending)",
      "gridPos": {
        "x": 12,
        "y": 31,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(recommendation_latency_seconds_count{source=\"model\"}[5m])) / sum(rate(recommendation_latency_seconds_count[5m]))",
          "legendFormat": "Model %"
        }
      ]
    },
    {
      "id": 16,
      "type": "stat",
      "title": "A/B Experiment Traffic %",
      "description": "% requests routed to experiment group (target: 10%)",
      "gridPos": {
        "x": 18,
        "y": 31,
        "w": 6,
        "h": 4
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.15
              },
              {
                "color": "red",
                "value": 0.25
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(http_requests_total{experiment_group=\"experiment\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "Experiment %"
        }
      ]
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Recommendation Latency by Source",
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 12,
        "h": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum(rate(recommendation_latency_seconds_bucket[5m])) by (le, source)) * 1000",
          "legendFormat": "P95 {{source}}"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum(rate(recommendation_latency_seconds_bucket[5m])) by (le, source)) * 1000",
          "legendFormat": "P50 {{source}}"
        }
      ]
    },
    {
      "id": 18,
      "type": "piechart",
      "title": "Recommendations by Source",
      "gridPos": {
        "x": 12,
        "y": 35,
        "w": 12,
        "h": 8
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        },
        "pieType": "pie"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(recommendation_latency_seconds_count[1h])) by (source)",
          "legendFormat": "{{source}}"
        }
      ]
    },
    {
      "id": 19,
      "type": "row",
      "title": "Infra (Redis)",
      "gridPos": {
        "x": 0,
        "y": 43,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Redis Cache Hit Rate",
      "gridPos": {
        "x": 0,
        "y": 44,
        "w": 6,
        "h": 8
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.7
              }
            ]
          }
